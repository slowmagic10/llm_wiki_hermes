# Copy to .env on the deployment host. Do not commit the real .env file.
AUTH_MODE=ldap
LDAP_URL=ldap://192.168.121.10:1389
LDAP_BASE_DN=dc=mynas
LDAP_USERS_RDN=cn=users
LDAP_ADMIN_USERS=knowledge-hub-admin
LDAP_CONNECT_TIMEOUT_SECONDS=5

# Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
AUTH_SESSION_TTL_SECONDS=28800

# Keep false only while the UI is accessed through HTTP on a trusted private network.
# Change to true before exposing Knowledge Hub through HTTPS.
AUTH_COOKIE_SECURE=false
